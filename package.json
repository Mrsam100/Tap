{
  "name": "tap",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web & npm run dev:api",
    "dev:web": "npm -w @tap/web run dev",
    "dev:api": "npm -w @tap/api run dev",
    "build": "npm -w @tap/web run build",
    "lint": "npm -w @tap/web run lint && npm -w @tap/api run lint",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules"
  }
}
