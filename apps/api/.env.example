# ── Required ──────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (sslmode=require, no channel_binding)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── Server ────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000
# Full URL of the frontend app (used in email links, OAuth redirects)
APP_URL=http://localhost:3000
# Full URL of the API (used for internal references)
API_URL=http://localhost:3001

# ── AI (Gemini) ───────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Email (Resend) ────────────────────────────────────────────────────
# Get your key at https://resend.com — required for email verification & password reset
RESEND_API_KEY=re_your_key_here

# ── OAuth ─────────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs for subscription plans (create in Stripe dashboard)
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# ── File Storage (S3 / Cloudflare R2) ────────────────────────────────
# Leave blank to use local filesystem (dev only — files lost on redeploy)
#
# Cloudflare R2:
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto
#   S3_ACCESS_KEY_ID=<R2 Access Key ID>
#   S3_SECRET_ACCESS_KEY=<R2 Secret Access Key>
#   S3_BUCKET_NAME=tap-uploads
#   UPLOAD_BASE_URL=https://your-r2-public-domain.com
#
# AWS S3:
#   S3_REGION=us-east-1
#   S3_ACCESS_KEY_ID=AKIA...
#   S3_SECRET_ACCESS_KEY=...
#   S3_BUCKET_NAME=tap-uploads
#   UPLOAD_BASE_URL=https://tap-uploads.s3.us-east-1.amazonaws.com
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
UPLOAD_BASE_URL=
